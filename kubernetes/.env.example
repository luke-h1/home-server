# Copy to kubernetes/.env (gitignored): cp kubernetes/.env.example kubernetes/.env
# Used by scripts/k8s.sh and scripts/cloudflare-tunnel.sh

export KUBECONFIG="${KUBECONFIG:-/etc/rancher/k3s/k3s.yaml}"

# --- Public hostnames (Ingress + Immich + Grafana) ---
export IMMICH_DOMAIN="images.example.com"
export IMMICH_PUBLIC_URL="https://images.example.com"
export GRAFANA_DOMAIN="grafana.example.com"
export GRAFANA_ROOT_URL="https://grafana.example.com"
export PROMETHEUS_DOMAIN="prometheus.example.com"
export ALERTS_DOMAIN="alerts.example.com"

export IMMICH_DB_PASSWORD="generate-a-long-random-password"
export GRAFANA_ADMIN_USER="admin"
export GRAFANA_ADMIN_PASSWORD="generate-a-strong-password"

export K3S_CHANNEL="stable"

# S3 backup (Immich Postgres dump CronJob; scripts/k8s.sh apply all)
export BACKUP_S3_BUCKET="your-bucket-name"
export BACKUP_S3_PREFIX="immich/pgdump"
export AWS_REGION="eu-west-2"

# Same bucket/prefix + backup-s3-credentials also feed the immich-server library-s3-backup sidecar
# (weekly aws s3 sync of photos → s3://.../library/ at Friday 00:00 UTC, same cadence as pgdump CronJob).
# Restore DB from S3: scripts/restore-immich-from-s3.sh (needs BACKUP_S3_* + backup-s3-credentials secret)

# --- Cloudflare Tunnel (scripts/cloudflare-tunnel.sh) ---
# export CLOUDFLARE_TUNNEL_TOKEN="eyJ..."
# File-based (render kubernetes/cloudflared-config.yml.tpl):
# export CLOUDFLARE_TUNNEL_ID="00000000-0000-0000-0000-000000000000"
# export CLOUDFLARE_TUNNEL_CREDENTIALS_FILE="/root/.cloudflared/${CLOUDFLARE_TUNNEL_ID}.json"
export CLOUDFLARE_TUNNEL_ORIGIN="http://127.0.0.1:80"

# Cloudflare → Prometheus (lablabs cloudflare_exporter; scripts/k8s.sh secrets)
# Token needs at least: Account Analytics:Read, Account Settings:Read (and Zone Analytics:Read for zone metrics).
# Account-scoped tokens: set CLOUDFLARE_ACCOUNT_IDS="your-account-uuid" (comma-separated for several).
# export CLOUDFLARE_EXPORTER_API_TOKEN=""
# export CLOUDFLARE_ACCOUNT_IDS=""
# export CLOUDFLARE_EXPORTER_ZONES=""
# export CLOUDFLARE_EXPORTER_EXCLUDE_ZONES=""
